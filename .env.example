# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_SECRET=replace_me
TELEGRAM_WEBHOOK_URL=https://your-domain.example/webhook/telegram

# Database (Postgres)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=telegram_ai
POSTGRES_USER=telegram_ai
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://telegram_ai:change_me@postgres:5432/telegram_ai

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=60

# Admin / manager auth
ADMIN_API_TOKEN=replace_me
MANAGER_USER_IDS=12345,67890

# Runtime
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

DATABASE_URL=sqlite+aiosqlite:///./telegram_ai.db
REDIS_URL=redis://localhost:6379/0

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
